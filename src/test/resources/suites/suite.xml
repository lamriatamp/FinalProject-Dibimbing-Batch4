<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Test Suite" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="core.TestListener"/>
    </listeners>

    <!-- UI Test -->
    <test name="Auth Tests">
        <classes>
            <class name="tests.ui.auth.LoginTest"/>
        </classes>
    </test>

    <test name="FTC Tests">
        <classes>
            <class name="tests.ui.fasttrackclass.CreateFastTrackClassTest"/>
        </classes>
    </test>

    <test name="Auth Api Test">
        <classes>
            <class name="tests.api.auth.LoginTest"/>
        </classes>
    </test>




</suite>